#
# kisa-audit — audit.conf
# ─────────────────────────────────────────────────────────────────────
# 사용:  cp config/audit.conf.example config/audit.conf
#        값만 수정 후 ./kisa-audit.sh apply --yes
#        권한은 자동으로 chmod 600 + chown root:root 강제됨
#
# 표기:  주석(#) 없는 라인 = 활성 설정 (값만 수정)
#        주석(#) 처리된 라인 = 사이트별 옵션 — 필요 시 # 풀고 사용
#
# 따옴표:
#   "..."  $/`/\ 가 bash 에 해석됨. 일반 값에 사용.
#   '...'  완전 문자 그대로. 비밀번호처럼 $ ` \ ! 같은 특수문자 들어갈 때 사용.
#

# ─────── SSH root 접속 제한 (U-01) ───────
# SSH 로 root 접속 중인 환경에서 "no" 로 두려면 사전에 sudo 가능 일반 계정
# (wheel 그룹 멤버) 가 있는지 확인 필요. 없으면 잠김 위험 — 아래 ADMIN_USER 로 자동 생성.
SSH_PERMIT_ROOT_LOGIN="no"           # no | yes | prohibit-password | forced-commands-only | 1=enable(yes) | 2=disable(no)

# ─────── SSH 포트 (E-01) ───────
# 빈값 ""    → 현재 포트 유지 (변경 안 함, 기본 동작)
# 값 지정 시 → 새 포트로 변경 + SELinux semanage + firewalld 허용 자동 처리.
#             ⚠️ 기존 22 는 sshd·방화벽에서 제거됨(22 fallback 없음) — 'systemctl restart sshd'
#                후 새 포트 로그인 검증 전까지 현재 세션 끊지 말 것.
SSH_PORT=""                          # 1~65535 | "" (=유지, 포트 변경 안 함)

# ─────── 관리자 계정 (U-01) ───────
# ADMIN_USER 빈값 → 기존 wheel 멤버 자동 탐색해서 사용 (멤버 있을 때).
# 새 계정 만들려면 계정명 입력 + PASSWORD 필수. 기존 계정이면 비밀번호 안 건드리고 wheel 보장.
ADMIN_USER=""                        # 예) "ops"
ADMIN_USER_PASSWORD=''               # 신규 계정 초기 비밀번호. 특수문자 안전하게 ''(작은따옴표) 사용

# ─────── sudo 권한 그룹 (U-63) ───────
# RHEL/Rocky 표준은 wheel. 다른 그룹 쓰는 사이트만 그룹명 변경.
SUDOERS_ADMIN_GROUP="wheel"          # 기본 wheel

# ─────── SELinux (E-02) ───────
# disabled→enforcing/permissive 역전환은 반드시 리부팅 필요.
#   "enforcing" | "permissive" | "disabled" → 해당 모드로 설정
#   빈값 ""    → 현재 상태 유지 (변경 없음, 기본 동작)
SELINUX_MODE=""                      # enforcing | permissive | disabled | "" (=유지) | 1=enforcing | 2=disabled

# ─────── 비밀번호·계정 정책 (U-02, U-03, U-12, U-30) ───────
PASSWORD_MIN_LEN=8                   # 최소 길이 (KISA: 8 이상)
PASSWORD_MAX_AGE=90                  # 최대 사용 기간(일) (KISA: 90 이하)
PASSWORD_MIN_AGE=1                   # 최소 사용 기간(일) (KISA: 1 이상)
PASSWORD_WARN_AGE=7                  # 만료 사전 경고(일)
LOGIN_MAX_RETRY=5                    # 잠금 임계값 (KISA: 10 이하)
LOGIN_LOCK_TIME=120                  # 자동 해제 대기(초) (KISA: 120 이상)
SESSION_TIMEOUT=600                  # 미사용 세션 종료(초) (KISA: 600 이하)
UMASK_VALUE=022                      # 시스템 기본 umask

# ─────── 로그인 배너 (U-62) ───────
# 사이트 자체 문구 쓸 때만 수정. 빈값으로 두면 스크립트 내장 동일 문구 자동 적용.
LOGIN_BANNER_TEXT='***************************************************************
  [경고] 본 시스템은 인가된 사용자만 사용할 수 있습니다.
  모든 접속 및 행위는 기록·감시되며, 비인가 접근 시
  관련 법령에 따라 민·형사상 처벌될 수 있습니다.

  WARNING: Authorized access only. All activity is
  monitored and recorded. Unauthorized access will be
  prosecuted to the full extent of the law.
***************************************************************'

# ─────── NFS (U-39, U-40) ───────
# 빈값             → nfs-server stop + disable + mask (NFS 미사용으로 판단)
# 값 있음          → /etc/exports 의 와일드카드 단독 호스트(*)를 첫 네트워크로 자동 교체
#                   nfs-server enable + active, exports ACL 적용
# ⚠️ 외부 클라이언트가 NFS mount 하려면 FIREWALL_SERVICES 에 "nfs,mountd,rpc-bind" 추가 필수
#   (KISA U-28 firewalld 기본 정책은 SSH 만 허용 — NFS 는 별도 명시)
NFS_ALLOWED_NETWORKS=""              # 콤마 구분 CIDR — 예) "192.168.200.0/24"

# ─────── SNMP (U-60, U-61) ───────
# SNMP_ALLOWED_NETWORKS 동작:
#   net-snmp 미설치 또는 snmpd 비활성  → 자동으로 N/A (이 변수와 무관)
#   SNMP_ALLOWED_NETWORKS 빈값         → snmpd stop + disable + mask
#   값 있음 + SNMP_COMMUNITY 명시 → snmpd.conf 에 rocommunity <key> <network> 추가
#                                       기존 v1/v2c community (public 등) 는 주석처리
# ⚠️ 외부 NMS 가 SNMP query 하려면 FIREWALL_PORTS 에 "161/udp" 추가 필수
SNMP_ALLOWED_NETWORKS=""             # 콤마 구분 CIDR — 예) "192.168.200.0/24"
SNMP_COMMUNITY=''               # SNMP community. audit.conf 권한 600 으로 자동 강제됨

# ─────── DNS BIND (U-50) ───────
# BIND ACL 문법값. "none" = Zone Transfer 전부 차단 (KISA 권고 가장 안전).
# 사이트가 secondary DNS 운용하면 IP/CIDR 로 교체.
# bind 미설치 시엔 이 변수와 무관하게 N/A.
# ⚠️ DNS query 외부 허용 시 FIREWALL_PORTS 또는 FIREWALL_SERVICES 에 "dns" 추가 필요
DNS_ZONE_ALLOW_TRANSFER="none"       # 예) "192.168.1.0/24" 또는 "{ 192.168.1.0/24; }"

# ─────── NTP (U-65) ───────
# 빈값                 → chrony.conf 의 vendor pool/server 라인 유지 (기본 동기화)
# 값 명시 (외부)       → chrony.conf 의 vendor 라인 주석처리 + server <addr> iburst 추가
# 값 명시 (폐쇄망)     → 폐쇄망 NTP 서버 IP 명시. 그 NTP 서버는
#                         chrony.conf 에 "allow <대역>" + "local stratum N" 추가 + 123/udp 허용 필요
NTP_SERVERS=""                       # 콤마 구분 — 예) "192.168.200.101" 또는 "kr.pool.ntp.org,time.bora.net"

# ─────── rsyslog 원격 전송 (U-66) ───────
# 기본 TCP/514. UDP 쓰려면 앞에 @ 붙이기.
#   "10.0.0.10"        → TCP 514 (자동)
#   "10.0.0.10:6514"   → TCP 6514
#   "@10.0.0.10:514"   → UDP 514
# 빈값이면 로컬 로그만 (rsyslog 자체는 active 유지 — 핵심 로그 수집).
# ⚠️ 원격 서버 도달 안 될 때는 audit.conf 의 IP/포트 오타 또는 방화벽 차단 확인 필요
RSYSLOG_REMOTE_SERVER=""             # 예) "10.0.0.10:514"

# ─────── 서비스 동작 (U-52, U-54) ───────
# FTP_MODE 동작 (vsftpd):
#   "disable" → vsftpd stop + disable + mask (KISA 권고 — 평문 FTP 차단)
#   "enable"  → vsftpd unmask + enable + start
#               + vsftpd.conf 보안 설정 강제 (anonymous_enable=NO, local_enable=YES, write_enable=NO,
#                 ftpd_banner 적용, userlist_enable=YES 등)
#               ⚠️ 평문 FTP 사용은 KISA 권고와 어긋남. 사이트 정책상 불가피한 경우만 사용.
#   "keep"    → 서비스 상태 그대로. vsftpd.conf 의 anonymous_enable=NO 만 설정.
FTP_MODE="disable"                   # disable | enable | keep | 1=enable | 2=disable
# TELNET_MODE 동작 (telnet-server):
#   "disable" → telnet.socket stop + disable + mask (KISA 권고 — 평문 telnet 차단)
#   "enable"  → telnet.socket unmask + enable + start
#               ⚠️ 평문 전송이라 KISA 권고와 어긋남. 사이트 정책상 불가피한 경우만 사용.
#               외부 클라이언트 접속 허용하려면 FIREWALL_PORTS 에 "23/tcp" 추가 필요.
#   "keep"    → 서비스 상태 그대로 (취약 판정 유지, 수동 조치 안내).
TELNET_MODE="disable"                # disable | enable | keep | 1=enable | 2=disable
# 패키지 자동 업데이트는 audit.conf 변수로 제어하지 않음.
# U-45/U-49/U-64 메일·DNS·OS 패치는 운영자가 직접 dnf update 로 수행 (수동 안내 항목).

# ─────── 사이트별 예외 (U-07, U-09) ───────
# U-07/U-09 는 절대 자동 삭제(userdel/groupdel) 수행하지 않음 — "담당자 확인 필요" 안내만 출력.
# 코드 내장 화이트리스트(mysql/postgres/apache/named/nginx 등 OS 기본 그룹) 는 자동 적용됨.
# 아래는 그 안내 목록에서 추가로 제외(또는 강제 노출) 할 사이트 고유 항목.
EXEMPT_ACCOUNTS=""                   # 콤마 구분 계정명 — 예) "tibero,svc_app1"
EXEMPT_GROUPS=""                     # 콤마 구분 그룹명
EXTRA_FLAG_GROUPS=""                 # 화이트리스트 무시하고 강제 노출할 그룹

# ─────── 방화벽 (E-03, E-04) ───────
# FIREWALL_MODE: firewalld 사용 여부
#   "enable"   → firewalld start + enable + FIREWALL_SERVICES/PORTS 적용
#   "disable"  → firewalld stop + disable + mask (외부 방화벽/보안장비 사용 사이트)
#                 ⚠️ 호스트 자체 방화벽이 꺼지므로 모든 포트가 OS 단에서 외부 노출됨.
#                 사이트의 외부 보안장비가 차단해주는지 사전 확인 필수.
#   빈값 ""    → 현재 상태 유지 (변경 없음, 기본 동작). FIREWALL_SERVICES/PORTS 도 적용 안 함.
FIREWALL_MODE=""                     # enable | disable | "" (=유지) | 1=enable | 2=disable

# FIREWALL_SERVICES: firewalld 의 사전 정의 service 이름 (콤마 구분)
#   각 service 는 자체 포트 정의를 포함 — 같은 포트를 FIREWALL_PORTS 에 중복 명시 불필요.
#   주요 사전 정의 service 와 포함 포트 (참고):
#     ssh        → 22/tcp
#     cockpit    → 9090/tcp
#     http       → 80/tcp
#     https      → 443/tcp
#     dns        → 53/tcp,53/udp
#     ntp        → 123/udp
#     nfs        → 2049/tcp (mountd / rpc-bind 별도 필요)
#     mountd     → 20048/tcp,20048/udp
#     rpc-bind   → 111/tcp,111/udp
#   사이트별 service 정의는 firewall-cmd --get-services 로 전체 목록 확인.
FIREWALL_SERVICES=""                 # 콤마 구분 — 예) "ssh,cockpit,http,https"

# FIREWALL_PORTS: 사전 정의 service 에 없는 포트만 명시 (콤마 구분).
#   FIREWALL_SERVICES 의 service 에 이미 포함된 포트는 중복 명시 불필요.
#   예) cockpit service 가 9090/tcp 를 포함하므로 FIREWALL_PORTS 에 "9090/tcp" 별도 X.
FIREWALL_PORTS=""                    # 콤마 구분 <port>/<proto> — 예) "8080/tcp,53/udp,10000-10100/tcp"

# ─────── 접속 IP/포트 제한 (U-28) ───────
# 방화벽(firewalld rich rule) 또는 TCP Wrapper 로 SSH 접속 허용 IP 를 제한.
ALLOWED_HOSTS=""                     # 콤마 구분 IP/CIDR — 빈값이면 manual (관리자 잠김 방지)
DENY_HOSTS=""                        # 콤마 구분 IP/CIDR. "ALL"=ALLOWED_HOSTS 외 전부 차단
